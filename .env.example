# 隅消息上稿系統 — 環境變數範本
# 規格文件第 8 節。複製一份為 .env(本機開發用),申請到一項憑證就填一項。
# .env 已列在 .gitignore,不會被提交。

# Railway 會自動提供,本機開發可留空(程式會 fallback 到預設 port,例如 3000)
PORT=

# 網頁介面登入密碼(簡易密碼保護,非完整會員系統)
ADMIN_PASSWORD=

# Claude API 金鑰,用於關鍵字抽取(model: claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=

# Pexels 圖庫 API 金鑰
PEXELS_API_KEY=

# Unsplash 圖庫 Access Key(demo 模式每小時 50 requests)
UNSPLASH_ACCESS_KEY=

# WordPress 站台網址,不含結尾斜線,例如 https://sousoucorner.org
WP_BASE_URL=

# WordPress Editor 專用帳號(非 admin)
WP_USERNAME=

# WordPress Application Password(於 WP 後台「使用者 > 個人資料」產生)
WP_APP_PASSWORD=

# Google Service Account 金鑰整份 JSON(單行或多行皆可,程式內 JSON.parse)
# 記得把目標 Drive 資料夾與 Sheet 分享給這個 Service Account 的 email(編輯權限)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Drive 根資料夾「隅消息」的 folder ID
DRIVE_ROOT_FOLDER_ID=

# Google Sheets 試算表 ID(記錄表)
SHEET_ID=
